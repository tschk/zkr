{
  "name": "@tschk/zkr-openclaw",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node --external openclaw/plugin-sdk/plugin-entry",
    "format": "bunx prettier --check .",
    "lint": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "openclaw": "2026.7.1-2",
    "prettier": "3.6.2",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1-2"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1-2",
      "minGatewayVersion": "2026.7.1-2"
    },
    "build": {
      "openclawVersion": "2026.7.1-2",
      "pluginSdkVersion": "2026.7.1-2"
    }
  }
}
